{
  "Server": {
    "HttpPort": 5000,
    "WebSocketPath": "/ws"
  },
  "Drivers": {
    "Pcsc": {
      "Enabled": true,
      "Mock": false,
      "AutoReconnect": true
    },
    "Printer": {
      "Enabled": true,
      "Mock": false
    },
    "IdCard": {
      "Enabled": false,
      "ComPort": "COM3"
    }
  },
  "Logging": {
    "RingBufferSize": 1000,
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
